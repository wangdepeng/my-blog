---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<h1>Welcome to My Blog</h1>
			<p>
				This is my personal blog where I share my thoughts, experiences, and things I learn along the way.
			</p>
			<p>
				Feel free to browse my posts and get in touch if you have any questions or just want to chat!
			</p>
		</main>
		<Footer />
	</body>
</html>
